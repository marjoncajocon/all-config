{
    "editor.fontLigatures": true,
    "editor.fontFamily": "Monaco Nerd Font",
    "editor.lineHeight": 1,
    "editor.cursorStyle": "block",
    "editor.cursorBlinking": "blink",
    "workbench.iconTheme": null,
    "editor.minimap.maxColumn": 40,
    "git.openRepositoryInParentFolders": "always",
    // "editor.inlineSuggest.enabled": true,
    // "github.copilot.enable": {
    //   "*": false,
    //   "typescript": true,
    //   "typescriptreact": true,
    //   "javascript": true,
    //   "javascriptreact": true
    // },
    /* 1. Disable language-specific tag closing */
    "html.autoClosingTags": false,
    "js/ts.autoClosingTags.enabled": false,
    /* 2. Disable Linked Editing (Highly recommended for Copilot users) */
    /* This prevents VS Code from automatically creating/editing a closing tag while you type the opening one */
    "editor.linkedEditing": false,
    /* 3. Optional: Disable bracket auto-closing if it still interferes */
    "editor.autoClosingBrackets": "never",
    "editor.autoClosingQuotes": "never",
    "workbench.editor.empty.hint": "hidden",
    "supermaven.enable": {
        "go": false,
        "sql": false
    },
    "workbench.activityBar.location": "hidden", // hides the activity bar
    "workbench.editor.tabSizing": "shrink", // shrinks the editor tabs
    "editor.glyphMargin": false,
    "editor.folding": false,
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "js/ts.experimental.useTsgo": true,
    "editor.lineNumbers": "off",
    "editor.scrollbar.verticalScrollbarSize": 3,
    "editor.scrollbar.horizontalScrollbarSize": 3,
    "editor.minimap.autohide": "none",
    "window.commandCenter": false,
    "workbench.layoutControl.enabled": false,
    "editor.renderWhitespace": "all",
    "workbench.editor.enablePreview": false,
    "editor.wordWrap": "off",
    "workbench.tree.indent": 7,
    "window.density.editorTabHeight": "compact",
    "window.zoomLevel": 0,
    "explorer.compactFolders": true,
    "editor.fontSize": 12.5,
    "editor.rulers": [
        {
            "column": 100
        }
    ],
    "workbench.colorTheme": "Monokai++",
    "files.autoSave": "afterDelay",
    "editor.formatOnSave": false,
    "redhat.telemetry.enabled": true
}
