{
    "editor.fontLigatures": true,
    "editor.fontFamily": "Cascadia Mono NF",
    "editor.lineHeight": 1,
    "editor.cursorStyle": "line",
    "editor.cursorBlinking": "solid",
    "workbench.iconTheme": "material-icon-theme",
    "editor.minimap.maxColumn": 40,
    "git.openRepositoryInParentFolders": "always",
    "workbench.productIconTheme": "material-product-icons",
    // "editor.inlineSuggest.enabled": true,
    // "github.copilot.enable": {
    //   "*": false,
    //   "typescript": true,
    //   "typescriptreact": true,
    //   "javascript": true,
    //   "javascriptreact": true
    // },
    /* 1. Disable language-specific tag closing */
    "html.autoClosingTags": false,
    "js/ts.autoClosingTags.enabled": false,
    
    /* 2. Disable Linked Editing (Highly recommended for Copilot users) */
    /* This prevents VS Code from automatically creating/editing a closing tag while you type the opening one */
    "editor.linkedEditing": false,

    /* 3. Optional: Disable bracket auto-closing if it still interferes */
    "editor.autoClosingBrackets": "never",
    "editor.autoClosingQuotes": "never",
    "workbench.editor.empty.hint": "hidden",
    "editor.fontSize": 13,
    "supermaven.enable": {
        "go": false,
        "sql": false
    },
    "workbench.colorTheme": "Monokai++ Unified",

    "workbench.activityBar.location": "hidden", // hides the activity bar
    "workbench.editor.tabSizing":"shrink", // shrinks the editor tabs
    "editor.glyphMargin": false,
    "editor.folding": false,
    
    "editor.tabSize": 4,
    "workbench.editor.enablePreview": false,
    "js/ts.experimental.useTsgo": true,
    "editor.lineNumbers": "off",
    "editor.scrollbar.verticalScrollbarSize": 3,
    "editor.scrollbar.horizontalScrollbarSize": 3,
    "editor.minimap.autohide": "scroll",
    "window.commandCenter": false,
    "workbench.layoutControl.enabled": false,
    "editor.renderWhitespace": "all"
}
